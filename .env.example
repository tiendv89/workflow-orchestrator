# Copy to .env and fill in values:
#   cp .env.example .env

# Workflow backend database URL
DATABASE_URL=

# UUIDs from the workspaces table — NOT the Qdrant WORKSPACE_ID string
WORKSPACE_ID=
ORGANIZATION_ID=

# Broker URL and Redis URL from the local-docker stack or your own setup
# To use the broker service in the local-docker stack, you need to add the following to your /etc/hosts file: # 127.0.1.1 broker
BROKER_URL=http://broker:7000 
REDIS_URL=redis://localhost:63790 # Exposed port 63790 from redis service in local-docker stack

GITHUB_TOKEN=

# SSH URLs for executor cloning (used in DispatchJob)
MANAGEMENT_REPO=

# Optional (defaults shown)
BASE_BRANCH=main
POLL_INTERVAL_SECONDS=15

HEALTH_PORT=8089
